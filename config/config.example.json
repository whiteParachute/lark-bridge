{
  "feishu": {
    "appId": "cli_your_app_id",
    "appSecret": "your_app_secret",
    "allowedSenders": ["ou_your_open_id"],
    "allowedChats": []
  },
  "defaultBackend": "claude",
  "claude": {
    "model": "opus",
    "effort": "max",
    "workspaceRoot": "~/workspace/lark-bridge",
    "additionalDirectories": [],
    "allowAllDirectories": false,
    "permissionMode": "auto"
  },
  "codex": {
    "model": "gpt-5.5",
    "modelReasoningEffort": "xhigh"
  },
  "tmux": {
    "enabled": false,
    "defaultProvider": "codex",
    "providerCommands": {
      "claude": "claude",
      "codex": "codex"
    },
    "captureLines": 200,
    "pollIntervalMs": 1000,
    "settleDelayMs": 15000,
    "turnTimeoutMs": 1200000
  },
  "session": {
    "idleTimeoutMs": 1800000,
    "maxDurationMs": 14400000
  },
  "daemon": {
    "mode": "nohup",
    "autoStart": false
  },
  "hooks": {
    "session": { "pre": [], "post": [] },
    "message": { "pre": [], "post": [] }
  },
  "log": {
    "level": "info"
  }
}
